#!/bin/sh

# Check argument count
if [ "$#" -ne 2 ]; then
    echo "Usage: $0 <image> <audio>"
        exit 1
	fi

	IMAGE=$1
	AUDIO=$2
	OUTPUT=output.mp4

	ffmpeg -y \
	    -loop 1 -i "$IMAGE" \
	        -i "$AUDIO" \
		    -vf "pad=ceil(iw/2)*2:ceil(ih/2)*2" \
		        -c:v libx264 -pix_fmt yuv420p \
			    -c:a copy \
			        -shortest \
				    "$OUTPUT"
